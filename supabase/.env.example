# Copy to supabase/.env and fill in. Used by `supabase start` (config.toml
# env() references) and `supabase functions serve --env-file supabase/.env`.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
CRON_SECRET=
# Locally, the auto-injected SUPABASE_URL is the internal Docker network
# hostname (e.g. http://kong:8000) — unreachable from a browser, so signed
# Storage URLs built from it are broken outside the container network. Set
# this to the externally-reachable API_URL from `supabase status`
# (typically http://127.0.0.1:54321) so products/index.ts can rewrite signed
# URLs before they reach the client. Leave unset in production — there
# SUPABASE_URL is already the public project URL, no rewrite needed.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
