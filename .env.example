# Copy to .env and fill in. Read by `supabase start` for config.toml's
# Google OAuth provider (env(SUPABASE_AUTH_GOOGLE_CLIENT_ID) / env(SUPABASE_AUTH_GOOGLE_SECRET)).
# Optional — leave blank unless you're testing Google sign-in locally.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
